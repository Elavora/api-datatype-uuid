{
    "name":  "elavora/api-datatype-uuid",
    "description":  "DataType UUID para aplicacoes Elavora API.",
    "type":  "library",
    "license":  "MIT",
    "require":  {
                    "php":  "\u003e=8.1",
                    "elavora/api-datatype-core":  "^0.1 || ^0.2"
                },
    "autoload":  {
                     "psr-4":  {
                                   "Elavora\\Api\\DataTypes\\":  "src/"
                               }
                 },
    "autoload-dev":  {
                         "psr-4":  {
                                       "Elavora\\Api\\DataTypes\\Uuid\\Tests\\":  "tests/"
                                   }
                     },
    "require-dev":  {
                        "phpunit/phpunit":  "^10.5 || ^11.0 || ^12.0"
                    },
    "scripts":  {
                    "lint":  "find src tests -name \u0027*.php\u0027 -print0 | xargs -0 -n1 php -l",
                    "test":  "phpunit -c phpunit.xml",
                    "check":  [
                                  "@lint",
                                  "@test"
                              ]
                },
    "config":  {
                   "sort-packages":  true
               },
    "extra":  {
                  "branch-alias":  {
                                       "dev-main":  "0.1-dev"
                                   }
              }
}
